# Temporal Cloud connection
TEMPORAL_NAMESPACE=tf-demo.zsvab
TEMPORAL_ADDRESS=tf-demo.zsvab.tmprl.cloud:7233
TEMPORAL_TLS=true
TEMPORAL_API_KEY=

# Temporal worker/API
TASK_QUEUE=trusted-friends-demo
DEFAULT_CONSENT_TTL_SECONDS=120

# Worker Deployment versioning
TEMPORAL_WORKER_DEPLOYMENT_NAME=trusted-friends-demo
TEMPORAL_WORKER_BUILD_ID=latest-8b4f
TEMPORAL_WORKER_VERSIONING=true

# API server
HOST=0.0.0.0
PORT=8000
